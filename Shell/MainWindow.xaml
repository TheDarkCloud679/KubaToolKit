<Window
    x:Class="KubaToolKit.Shell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="KubaToolKit"
    Height="780"
    Width="1400"
    MinHeight="700"
    MinWidth="1200"
    WindowStartupLocation="CenterScreen">
    <Grid Margin="8">
        <Grid.RowDefinitions>

            <!-- Filters -->
            <RowDefinition Height="Auto"/>

            <!-- Splitter -->
            <RowDefinition Height="5"/>

            <!-- Active module -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================================================== -->
        <!-- HEADER -->
        <!-- ===================================================== -->

        <Border
            Grid.Row="0"
            Padding="8"
            Margin="0,0,0,6"
            BorderBrush="#DADADA"
            BorderThickness="1"
            CornerRadius="4"
            Background="#FAFAFA">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="260"/>

                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="180"/>

                        <ColumnDefinition Width="240"/>

                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Profile -->
                    <TextBlock
        Grid.Column="0"
        VerticalAlignment="Center"
        FontWeight="SemiBold"
        Text="Profile"/>

                    <ComboBox
        x:Name="ProfileCombo"
        Grid.Column="1"
        Height="28"
        Margin="6,0,12,0"
        SelectionChanged="ProfileCombo_SelectionChanged"/>

                    <!-- Pattern -->
                    <TextBlock
        Grid.Column="2"
        VerticalAlignment="Center"
        FontWeight="SemiBold"
        Text="Pattern"/>

                    <ComboBox
        x:Name="PatternCombo"
        Grid.Column="3"
        Height="28"
        Margin="6,0,12,0"
        SelectionChanged="PatternCombo_SelectionChanged"/>

                    <!-- Source -->
                    <StackPanel
        Grid.Column="4"
        Orientation="Horizontal"
        VerticalAlignment="Center"
        Margin="6,0,12,0">

                        <TextBlock
            Text="Source"
            VerticalAlignment="Center"
            Margin="0,0,8,0"
            FontWeight="SemiBold"/>

                        <RadioButton
            x:Name="CloudWatchModeRadio"
            Content="CloudWatch"
            IsChecked="True"
            GroupName="Mode"
            Checked="ModeRadio_Checked"
            VerticalAlignment="Center"/>

                        <RadioButton
            x:Name="S3ModeRadio"
            Content="S3 Explorer"
            Margin="10,0,0,0"
            GroupName="Mode"
            Checked="ModeRadio_Checked"
            VerticalAlignment="Center"/>

                    </StackPanel>

                    <!-- Search -->
                    <TextBlock
        Grid.Column="5"
        VerticalAlignment="Center"
        FontWeight="SemiBold"
        Text="Search"/>

                    <TextBox
        x:Name="SearchTextBox"
        Grid.Column="6"
        Height="28"
        Margin="6,0,0,0"
        VerticalContentAlignment="Center"
        KeyDown="SearchTextBox_KeyDown"/>
                </Grid>

                <!-- Ligne 2 -->
                <Grid
                    Grid.Row="1"
                    Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="35"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="Start"/>
                    <DatePicker
                        x:Name="StartDatePicker"
                        Grid.Column="1"
                        Height="28"
                        VerticalContentAlignment="Center"
                        CalendarOpened="DatePicker_CalendarOpened"/>
                    <TextBox
                        x:Name="StartTimeTextBox"
                        Grid.Column="2"
                        Height="25"
                        Margin="6,4,10,2"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Left"
                        Padding="0"
                        LostFocus="TimeTextBox_LostFocus"
                        PreviewKeyDown="TimeTextBox_PreviewKeyDown"
                        GotKeyboardFocus="TimeTextBox_GotKeyboardFocus"
                        PreviewMouseLeftButtonDown="TimeTextBox_PreviewMouseLeftButtonDown"/>
                    <TextBlock
                        Grid.Column="4"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="End"/>
                    <DatePicker
                        x:Name="EndDatePicker"
                        Grid.Column="5"
                        Height="28"
                        VerticalContentAlignment="Center"
                        CalendarOpened="DatePicker_CalendarOpened" Margin="0,3,0,1"/>
                    <TextBox
                        x:Name="EndTimeTextBox"
                        Grid.Column="6"
                        Height="26"
                        Margin="6,4,10,2"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Left"
                        Padding="0"
                        LostFocus="TimeTextBox_LostFocus"
                        PreviewKeyDown="TimeTextBox_PreviewKeyDown"
                        GotKeyboardFocus="TimeTextBox_GotKeyboardFocus"
                        PreviewMouseLeftButtonDown="TimeTextBox_PreviewMouseLeftButtonDown"/>
                    <StackPanel
    Grid.Column="8"
    Orientation="Horizontal"
    HorizontalAlignment="Right">

                        <Button
        x:Name="SearchButton"
        Width="80"
        Height="32"
        Content="Search"
        FontWeight="SemiBold"
        Click="SearchButton_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
        <GridSplitter
               Grid.Row="1"
               Height="5"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Center"
               Background="#D0D0D0"
               ResizeBehavior="PreviousAndNext"
               ResizeDirection="Rows"/>

        <!-- ===================================================== -->
        <!-- ACTIVE MODULE -->
        <!-- ===================================================== -->

        <Grid
            x:Name="ModuleHost"
            Grid.Row="2"/>
    </Grid>
</Window>

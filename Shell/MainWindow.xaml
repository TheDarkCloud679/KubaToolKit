<Window
    x:Class="KubaToolKit.Shell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="KubaToolKit"
    Height="780"
    Width="1400"
    MinHeight="700"
    MinWidth="1200"
    WindowStartupLocation="CenterScreen">
    <Grid Margin="12" Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>

            <!-- Filters -->
            <RowDefinition Height="Auto"/>

            <!-- Splitter -->
            <RowDefinition Height="6"/>

            <!-- Active module -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================================================== -->
        <!-- HEADER -->
        <!-- ===================================================== -->

        <Border
            Grid.Row="0"
            Padding="16,14"
            Margin="0,0,0,10"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource HeaderBrush}"
            Effect="{StaticResource CardShadowEffect}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand -->
                <StackPanel
                    Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,14">
                    <Border
                        Width="28"
                        Height="28"
                        CornerRadius="7"
                        Background="{StaticResource AccentBrush}">
                        <TextBlock
                            Text="K"
                            FontWeight="Bold"
                            FontSize="14"
                            Foreground="{StaticResource TextOnAccentBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            Text="KubaToolKit"
                            FontWeight="Bold"
                            FontSize="16"
                            Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock
                            Text="AWS CloudWatch Logs &amp; S3 Explorer"
                            FontSize="11"
                            Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Row="1">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="260"/>

                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="180"/>

                        <ColumnDefinition Width="260"/>

                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Profile -->
                    <TextBlock
        Grid.Column="0"
        VerticalAlignment="Center"
        FontWeight="SemiBold"
        Foreground="{StaticResource TextSecondaryBrush}"
        Text="Profile"/>

                    <ComboBox
        x:Name="ProfileCombo"
        Grid.Column="1"
        Margin="6,0,12,0"
        SelectionChanged="ProfileCombo_SelectionChanged"/>

                    <!-- Pattern -->
                    <TextBlock
        Grid.Column="2"
        VerticalAlignment="Center"
        FontWeight="SemiBold"
        Foreground="{StaticResource TextSecondaryBrush}"
        Text="Pattern"/>

                    <ComboBox
        x:Name="PatternCombo"
        Grid.Column="3"
        Margin="6,0,12,0"
        SelectionChanged="PatternCombo_SelectionChanged"/>

                    <!-- Source -->
                    <StackPanel
        Grid.Column="4"
        Orientation="Horizontal"
        VerticalAlignment="Center"
        Margin="6,0,12,0">

                        <TextBlock
            Text="Source"
            VerticalAlignment="Center"
            Margin="0,0,10,0"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextSecondaryBrush}"/>

                        <RadioButton
            x:Name="CloudWatchModeRadio"
            Content="CloudWatch"
            IsChecked="True"
            GroupName="Mode"
            Checked="ModeRadio_Checked"
            VerticalAlignment="Center"/>

                        <RadioButton
            x:Name="S3ModeRadio"
            Content="S3 Explorer"
            Margin="16,0,0,0"
            GroupName="Mode"
            Checked="ModeRadio_Checked"
            VerticalAlignment="Center"/>

                    </StackPanel>

                    <!-- Search -->
                    <TextBlock
        Grid.Column="5"
        VerticalAlignment="Center"
        FontWeight="SemiBold"
        Foreground="{StaticResource TextSecondaryBrush}"
        Text="Search"/>

                    <TextBox
        x:Name="SearchTextBox"
        Grid.Column="6"
        Margin="6,0,0,0"
        VerticalContentAlignment="Center"
        KeyDown="SearchTextBox_KeyDown"/>
                </Grid>

                <!-- Ligne 2 -->
                <Grid
                    Grid.Row="2"
                    Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="35"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Start"/>
                    <DatePicker
                        x:Name="StartDatePicker"
                        Grid.Column="1"
                        VerticalContentAlignment="Center"
                        CalendarOpened="DatePicker_CalendarOpened"/>
                    <TextBox
                        x:Name="StartTimeTextBox"
                        Grid.Column="2"
                        Margin="6,0,10,0"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Left"
                        LostFocus="TimeTextBox_LostFocus"
                        PreviewKeyDown="TimeTextBox_PreviewKeyDown"
                        GotKeyboardFocus="TimeTextBox_GotKeyboardFocus"
                        PreviewMouseLeftButtonDown="TimeTextBox_PreviewMouseLeftButtonDown"/>
                    <TextBlock
                        Grid.Column="4"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="End"/>
                    <DatePicker
                        x:Name="EndDatePicker"
                        Grid.Column="5"
                        VerticalContentAlignment="Center"
                        CalendarOpened="DatePicker_CalendarOpened"/>
                    <TextBox
                        x:Name="EndTimeTextBox"
                        Grid.Column="6"
                        Margin="6,0,10,0"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Left"
                        LostFocus="TimeTextBox_LostFocus"
                        PreviewKeyDown="TimeTextBox_PreviewKeyDown"
                        GotKeyboardFocus="TimeTextBox_GotKeyboardFocus"
                        PreviewMouseLeftButtonDown="TimeTextBox_PreviewMouseLeftButtonDown"/>
                    <StackPanel
    Grid.Column="8"
    Orientation="Horizontal"
    HorizontalAlignment="Right">

                        <Button
        x:Name="SearchButton"
        Width="90"
        Style="{StaticResource AccentButtonStyle}"
        Content="Search"
        Click="SearchButton_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
        <GridSplitter
               Grid.Row="1"
               Height="6"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Center"
               ResizeBehavior="PreviousAndNext"
               ResizeDirection="Rows"/>

        <!-- ===================================================== -->
        <!-- ACTIVE MODULE -->
        <!-- ===================================================== -->

        <Grid
            x:Name="ModuleHost"
            Grid.Row="2"/>
    </Grid>
</Window>

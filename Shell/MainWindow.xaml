<Window
    x:Class="KubaToolKit.Shell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:KubaToolKit.Shared.Behaviors"
    Title="KubaToolKit"
    Height="780"
    Width="1400"
    MinHeight="700"
    MinWidth="1200"
    WindowStartupLocation="CenterScreen">
    <Grid Margin="12" Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>

            <!-- Filters -->
            <RowDefinition Height="Auto"/>

            <!-- Splitter -->
            <RowDefinition Height="6"/>

            <!-- Active module -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================================================== -->
        <!-- HEADER -->
        <!-- ===================================================== -->

        <Border
            Grid.Row="0"
            Padding="16,14"
            Margin="0,0,0,10"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMedium}"
            Background="{StaticResource HeaderBrush}"
            Effect="{StaticResource CardShadowEffect}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand -->
                <StackPanel
                    Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,14">
                    <Border
                        Width="34"
                        Height="34"
                        CornerRadius="{StaticResource RadiusMedium}"
                        Effect="{StaticResource CardShadowEffect}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{StaticResource AccentColor}" Offset="0"/>
                                <GradientStop Color="{StaticResource AccentPressedColor}" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock
                            Text="K"
                            FontWeight="Bold"
                            FontSize="16"
                            Foreground="{StaticResource TextOnAccentBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Text="KubaToolKit"
                                FontWeight="Bold"
                                FontSize="16"
                                Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock
                                x:Name="VersionTextBlock"
                                FontSize="10"
                                Margin="6,0,0,2"
                                VerticalAlignment="Bottom"
                                Foreground="{StaticResource TextMutedBrush}"
                                ToolTip="Version de KubaToolKit"/>
                        </StackPanel>
                        <TextBlock
                            Text="AWS Ops &amp; API Toolkit"
                            FontSize="11"
                            Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Source -->
                <StackPanel
                    Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,12">

                    <TextBlock
                        Text="Source"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"/>

                    <WrapPanel VerticalAlignment="Center">
                        <RadioButton
                            x:Name="DashboardModeRadio"
                            Content="Dashboard"
                            IsChecked="True"
                            GroupName="Mode"
                            Checked="ModeRadio_Checked"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0"/>

                        <RadioButton
                            x:Name="CloudWatchModeRadio"
                            Content="CloudWatch"
                            GroupName="Mode"
                            Checked="ModeRadio_Checked"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0"/>

                        <RadioButton
                            x:Name="CloudTrailModeRadio"
                            Content="CloudTrail"
                            GroupName="Mode"
                            Checked="ModeRadio_Checked"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0"/>

                        <RadioButton
                            x:Name="S3ModeRadio"
                            Content="S3 Explorer"
                            GroupName="Mode"
                            Checked="ModeRadio_Checked"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0"/>

                        <RadioButton
                            x:Name="SqsModeRadio"
                            Content="SQS"
                            GroupName="Mode"
                            Checked="ModeRadio_Checked"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0"/>

                        <RadioButton
                            x:Name="StepFunctionsModeRadio"
                            Content="Step Functions"
                            GroupName="Mode"
                            Checked="ModeRadio_Checked"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0"/>

                        <RadioButton
                            x:Name="ApiClientModeRadio"
                            Content="API Client"
                            GroupName="Mode"
                            Checked="ModeRadio_Checked"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0"/>

                        <RadioButton
                            x:Name="PandoraModeRadio"
                            Content="Pandora"
                            GroupName="Mode"
                            Checked="ModeRadio_Checked"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0"/>
                    </WrapPanel>
                </StackPanel>

                <Grid
                    x:Name="ProfilePatternSearchRow"
                    Grid.Row="2">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Profile : utile à tous les modules AWS, seule la ligne entière se masque (API Client) -->
                    <Grid x:Name="ProfileGroup" Grid.Column="0" Margin="0,0,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Profile"/>

                        <ComboBox
                            x:Name="ProfileCombo"
                            Grid.Column="1"
                            Margin="6,0,0,0"
                            SelectionChanged="ProfileCombo_SelectionChanged"/>
                    </Grid>

                    <!-- Profile Pandora : uniquement utile en mode Pandora. Partage
                         la colonne du Profile AWS puisque les deux mondes de
                         profils/identifiants sont mutuellement exclusifs. -->
                    <Grid x:Name="PandoraProfileGroup" Grid.Column="0" Margin="0,0,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Profile"/>

                        <ComboBox
                            x:Name="PandoraProfileCombo"
                            Grid.Column="1"
                            Margin="6,0,0,0"
                            SelectionChanged="PandoraProfileCombo_SelectionChanged"/>
                    </Grid>

                    <!-- Pattern : uniquement utile en mode CloudWatch -->
                    <Grid x:Name="PatternGroup" Grid.Column="1" Margin="0,0,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Pattern"/>

                        <ComboBox
                            x:Name="PatternCombo"
                            Grid.Column="1"
                            Margin="6,0,0,0"
                            SelectionChanged="PatternCombo_SelectionChanged"/>
                    </Grid>

                    <!-- Attribute : uniquement utile en mode CloudTrail. Partage la
                         colonne de Pattern (CloudWatch) puisque les deux modes ne
                         sont jamais actifs en même temps. -->
                    <Grid x:Name="AttributeGroup" Grid.Column="1" Margin="0,0,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Attribute"/>

                        <ComboBox
                            x:Name="CloudTrailAttributeCombo"
                            Grid.Column="1"
                            Margin="6,0,0,0"/>
                    </Grid>

                    <!-- Search : utile en CloudWatch (filtre logs), CloudTrail
                         (valeur de l'attribut) et S3 (recherche dans les dossiers) -->
                    <Grid x:Name="SearchGroup" Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Search"/>

                        <TextBox
                            x:Name="SearchTextBox"
                            Grid.Column="1"
                            Margin="6,0,12,0"
                            VerticalContentAlignment="Center"
                            KeyDown="SearchTextBox_KeyDown"/>
                    </Grid>

                    <!-- Bouton d'action partagé (Search/Refresh/Cancel selon le module) : toujours sur la même ligne que Search -->
                    <Button
                        x:Name="SearchButton"
                        Grid.Column="3"
                        Width="90"
                        Style="{StaticResource AccentButtonStyle}"
                        Content="Search"
                        Click="SearchButton_Click"/>
                </Grid>

                <!-- Ligne 2 : dates/heures, uniquement utiles en mode CloudWatch -->
                <Grid
                    x:Name="DateRangeRow"
                    Grid.Row="3"
                    Margin="0,12,0,0">

                    <Grid x:Name="DateFieldsGroup" HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Margin="0,0,8,0"
                            Text="Start"/>
                        <DatePicker
                            x:Name="StartDatePicker"
                            Grid.Column="1"
                            Width="85"
                            Tag="Date de début"
                            VerticalContentAlignment="Center"
                            CalendarOpened="DatePicker_CalendarOpened"/>
                        <TextBox
                            x:Name="StartTimeTextBox"
                            Grid.Column="2"
                            Width="70"
                            Margin="8,0,0,0"
                            VerticalContentAlignment="Center"
                            HorizontalContentAlignment="Center"
                            behaviors:TimeEntryBehavior.Enabled="True"/>
                        <TextBlock
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Margin="24,0,8,0"
                            Text="End"/>
                        <DatePicker
                            x:Name="EndDatePicker"
                            Grid.Column="4"
                            Width="85"
                            Tag="Date de fin"
                            VerticalContentAlignment="Center"
                            CalendarOpened="DatePicker_CalendarOpened"/>
                        <TextBox
                            x:Name="EndTimeTextBox"
                            Grid.Column="5"
                            Width="70"
                            Margin="8,0,0,0"
                            VerticalContentAlignment="Center"
                            HorizontalContentAlignment="Center"
                            behaviors:TimeEntryBehavior.Enabled="True"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
        <GridSplitter
               Grid.Row="1"
               Height="6"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Center"
               ResizeBehavior="PreviousAndNext"
               ResizeDirection="Rows"/>

        <!-- ===================================================== -->
        <!-- ACTIVE MODULE -->
        <!-- ===================================================== -->

        <Grid
            x:Name="ModuleHost"
            Grid.Row="2"/>
    </Grid>
</Window>

<Window
    x:Class="KubaToolKit.Shell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="KubaToolKit"
    Height="780"
    Width="1400"
    MinHeight="700"
    MinWidth="1200"
    WindowStartupLocation="CenterScreen">
    <Grid Margin="12" Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>

            <!-- Filters -->
            <RowDefinition Height="Auto"/>

            <!-- Splitter -->
            <RowDefinition Height="6"/>

            <!-- Active module -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================================================== -->
        <!-- HEADER -->
        <!-- ===================================================== -->

        <Border
            Grid.Row="0"
            Padding="16,14"
            Margin="0,0,0,10"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource HeaderBrush}"
            Effect="{StaticResource CardShadowEffect}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand -->
                <StackPanel
                    Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="0,0,0,14">
                    <Border
                        Width="28"
                        Height="28"
                        CornerRadius="7"
                        Background="{StaticResource AccentBrush}">
                        <TextBlock
                            Text="K"
                            FontWeight="Bold"
                            FontSize="14"
                            Foreground="{StaticResource TextOnAccentBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock
                            Text="KubaToolKit"
                            FontWeight="Bold"
                            FontSize="16"
                            Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock
                            Text="AWS CloudWatch Logs &amp; S3 Explorer"
                            FontSize="11"
                            Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Source -->
                <StackPanel
                    Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,12">

                    <TextBlock
                        Text="Source"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"/>

                    <WrapPanel VerticalAlignment="Center">
                        <RadioButton
                            x:Name="DashboardModeRadio"
                            Content="Dashboard"
                            IsChecked="True"
                            GroupName="Mode"
                            Checked="ModeRadio_Checked"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0"/>

                        <RadioButton
                            x:Name="CloudWatchModeRadio"
                            Content="CloudWatch"
                            GroupName="Mode"
                            Checked="ModeRadio_Checked"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0"/>

                        <RadioButton
                            x:Name="S3ModeRadio"
                            Content="S3 Explorer"
                            GroupName="Mode"
                            Checked="ModeRadio_Checked"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0"/>

                        <RadioButton
                            x:Name="SqsModeRadio"
                            Content="SQS"
                            GroupName="Mode"
                            Checked="ModeRadio_Checked"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0"/>

                        <RadioButton
                            x:Name="StepFunctionsModeRadio"
                            Content="Step Functions"
                            GroupName="Mode"
                            Checked="ModeRadio_Checked"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0"/>

                        <RadioButton
                            x:Name="ApiClientModeRadio"
                            Content="API Client"
                            GroupName="Mode"
                            Checked="ModeRadio_Checked"
                            VerticalAlignment="Center"
                            Margin="0,0,20,0"/>
                    </WrapPanel>
                </StackPanel>

                <Grid
                    x:Name="ProfilePatternSearchRow"
                    Grid.Row="2">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Profile : utile à tous les modules AWS, seule la ligne entière se masque (API Client) -->
                    <Grid x:Name="ProfileGroup" Grid.Column="0" Margin="0,0,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Profile"/>

                        <ComboBox
                            x:Name="ProfileCombo"
                            Grid.Column="1"
                            Margin="6,0,0,0"
                            SelectionChanged="ProfileCombo_SelectionChanged"/>
                    </Grid>

                    <!-- Pattern : uniquement utile en mode CloudWatch -->
                    <Grid x:Name="PatternGroup" Grid.Column="1" Margin="0,0,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Pattern"/>

                        <ComboBox
                            x:Name="PatternCombo"
                            Grid.Column="1"
                            Margin="6,0,0,0"
                            SelectionChanged="PatternCombo_SelectionChanged"/>
                    </Grid>

                    <!-- Search : utile en CloudWatch (filtre logs) et S3 (recherche dans les dossiers) -->
                    <Grid x:Name="SearchGroup" Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Search"/>

                        <TextBox
                            x:Name="SearchTextBox"
                            Grid.Column="1"
                            Margin="6,0,0,0"
                            MaxWidth="420"
                            HorizontalAlignment="Left"
                            VerticalContentAlignment="Center"
                            KeyDown="SearchTextBox_KeyDown"/>
                    </Grid>
                </Grid>

                <!-- Ligne 2 -->
                <Grid
                    x:Name="DateRangeRow"
                    Grid.Row="3"
                    Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Dates/heures : uniquement utiles en mode CloudWatch -->
                    <Grid x:Name="DateFieldsGroup" Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Margin="0,0,8,0"
                            Text="Start"/>
                        <DatePicker
                            x:Name="StartDatePicker"
                            Grid.Column="1"
                            Width="85"
                            Tag="Date de début"
                            VerticalContentAlignment="Center"
                            CalendarOpened="DatePicker_CalendarOpened"/>
                        <TextBox
                            x:Name="StartTimeTextBox"
                            Grid.Column="2"
                            Width="70"
                            Margin="8,0,0,0"
                            VerticalContentAlignment="Center"
                            HorizontalContentAlignment="Center"
                            LostFocus="TimeTextBox_LostFocus"
                            PreviewKeyDown="TimeTextBox_PreviewKeyDown"
                            GotKeyboardFocus="TimeTextBox_GotKeyboardFocus"
                            PreviewMouseLeftButtonDown="TimeTextBox_PreviewMouseLeftButtonDown"/>
                        <TextBlock
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Margin="24,0,8,0"
                            Text="End"/>
                        <DatePicker
                            x:Name="EndDatePicker"
                            Grid.Column="4"
                            Width="85"
                            Tag="Date de fin"
                            VerticalContentAlignment="Center"
                            CalendarOpened="DatePicker_CalendarOpened"/>
                        <TextBox
                            x:Name="EndTimeTextBox"
                            Grid.Column="5"
                            Width="70"
                            Margin="8,0,0,0"
                            VerticalContentAlignment="Center"
                            HorizontalContentAlignment="Center"
                            LostFocus="TimeTextBox_LostFocus"
                            PreviewKeyDown="TimeTextBox_PreviewKeyDown"
                            GotKeyboardFocus="TimeTextBox_GotKeyboardFocus"
                            PreviewMouseLeftButtonDown="TimeTextBox_PreviewMouseLeftButtonDown"/>
                    </Grid>

                    <!-- Bouton d'action partagé (Search/Refresh/Cancel selon le module) : toujours visible -->
                    <Button
                        x:Name="SearchButton"
                        Grid.Column="2"
                        Width="90"
                        Style="{StaticResource AccentButtonStyle}"
                        Content="Search"
                        Click="SearchButton_Click"/>
                </Grid>
            </Grid>
        </Border>
        <GridSplitter
               Grid.Row="1"
               Height="6"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Center"
               ResizeBehavior="PreviousAndNext"
               ResizeDirection="Rows"/>

        <!-- ===================================================== -->
        <!-- ACTIVE MODULE -->
        <!-- ===================================================== -->

        <Grid
            x:Name="ModuleHost"
            Grid.Row="2"/>
    </Grid>
</Window>

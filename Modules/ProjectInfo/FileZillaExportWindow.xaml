<Window
    x:Class="KubaToolKit.Modules.ProjectInfo.FileZillaExportWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Export to FileZilla"
    Width="460"
    SizeToContent="Height"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">

        <TextBlock
            Text="Writes directly into FileZilla's Site Manager (sitemanager.xml). Close FileZilla first, or it may overwrite this on its own exit. A timestamped backup is made before writing."
            TextWrapping="Wrap"
            FontSize="11"
            Foreground="{StaticResource TextSecondaryBrush}"
            Margin="0,0,0,14"/>

        <TextBlock Text="Column for the site name" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <ComboBox x:Name="NameColumnCombo" Margin="0,0,0,10"/>

        <TextBlock Text="Column for the host/IP" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <ComboBox x:Name="HostColumnCombo" Margin="0,0,0,10"/>

        <TextBlock Text="SFTP username (same for every row)" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="UsernameTextBox" Margin="0,0,0,10"/>

        <TextBlock Text="Port" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="PortTextBox" Text="22" Width="80" HorizontalAlignment="Left" Margin="0,0,0,10"/>

        <TextBlock Text="Private key file (same for every row)" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox
                x:Name="KeyFileTextBox"
                Grid.Column="0"
                ToolTip="You can type/paste a path directly -- useful if the key lives on another machine than the one you're exporting from."/>
            <Button Grid.Column="1" Content="Browse..." Margin="6,0,0,0" Click="BrowseKeyFile_Click"/>
        </Grid>

        <TextBlock Text="Folder name in FileZilla's Site Manager" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="FolderNameTextBox" Margin="0,0,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button Content="Export" Width="90" Style="{StaticResource AccentButtonStyle}" Click="ExportButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>

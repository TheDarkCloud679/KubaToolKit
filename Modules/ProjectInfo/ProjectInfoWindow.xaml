<Window
    x:Class="KubaToolKit.Modules.ProjectInfo.ProjectInfoWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Project Info"
    Width="1000"
    Height="700"
    MinWidth="600"
    MinHeight="400"
    WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock
            x:Name="TitleTextBlock"
            Grid.Row="0"
            FontWeight="Bold"
            FontSize="16"
            Margin="0,0,0,4"
            Foreground="{StaticResource TextPrimaryBrush}"/>

        <StackPanel
            Grid.Row="1"
            Orientation="Horizontal"
            Margin="0,0,0,14">

            <TextBlock
                Text="Project"
                VerticalAlignment="Center"
                Margin="0,0,8,0"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextSecondaryBrush}"/>

            <TextBox
                x:Name="ProjectKeyTextBox"
                Width="220"
                VerticalContentAlignment="Center"
                LostFocus="ProjectKeyTextBox_LostFocus"
                ToolTip="Prod/Preprod/Test profiles of the same project share this information automatically (the _prod/_preprod/_test suffix is detected and stripped). Override it here to force two profiles to share, or to split them."/>

            <TextBlock
                Text="(Prod/Preprod/Test of the same project share info automatically)"
                VerticalAlignment="Center"
                Margin="8,0,0,0"
                FontSize="11"
                FontStyle="Italic"
                Foreground="{StaticResource TextMutedBrush}"/>

            <Button
                Content="📁 Files folder"
                Margin="16,0,0,0"
                Padding="10,2"
                Click="OpenProjectFolderButton_Click"
                ToolTip="Opens (and creates if needed) a shared folder for this project, to drop files alongside this glossary."/>
        </StackPanel>

        <StackPanel
            Grid.Row="2"
            Orientation="Horizontal"
            Margin="0,0,0,14">

            <TextBlock
                Text="Search"
                VerticalAlignment="Center"
                Margin="0,0,8,0"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextSecondaryBrush}"/>

            <TextBox
                x:Name="SearchTextBox"
                Width="240"
                VerticalContentAlignment="Center"
                KeyDown="SearchTextBox_KeyDown"
                ToolTip="Searches across all sections/columns of this project. Enter = next result, Shift+Enter = previous."/>

            <Button
                Content="▲"
                Width="30"
                Padding="0"
                Margin="6,0,0,0"
                Click="SearchPreviousButton_Click"
                ToolTip="Previous result"/>

            <Button
                Content="▼"
                Width="30"
                Padding="0"
                Margin="4,0,0,0"
                Click="SearchNextButton_Click"
                ToolTip="Next result"/>

            <TextBlock
                x:Name="SearchResultsText"
                VerticalAlignment="Center"
                Margin="10,0,0,0"
                FontSize="11"
                Foreground="{StaticResource TextMutedBrush}"/>
        </StackPanel>

        <StackPanel
            Grid.Row="3"
            Orientation="Horizontal"
            Margin="0,0,0,14">

            <TextBlock
                Text="Add section"
                VerticalAlignment="Center"
                Margin="0,0,8,0"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextSecondaryBrush}"/>

            <ComboBox
                x:Name="SectionPresetCombo"
                Width="160"
                Margin="0,0,8,0"
                VerticalContentAlignment="Center"/>

            <TextBox
                x:Name="NewSectionNameTextBox"
                Width="200"
                Margin="0,0,8,0"
                VerticalContentAlignment="Center"
                ToolTip="Section name (leave empty to use the template name)"/>

            <Button
                Content="Add section"
                Width="110"
                Style="{StaticResource AccentButtonStyle}"
                Click="AddSectionButton_Click"/>
        </StackPanel>

        <ScrollViewer
            x:Name="SectionsScrollViewer"
            Grid.Row="4"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="SectionsPanel"/>
        </ScrollViewer>
    </Grid>
</Window>

<UserControl
    x:Class="KubaToolKit.Modules.StepFunctions.StepFunctionsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock
                    Text="Step Functions"
                    FontWeight="Bold"
                    FontSize="14"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    VerticalAlignment="Center"/>

                <TextBlock
                    Text="(double-click a state machine for its executions, or a header to sort)"
                    FontSize="11"
                    FontStyle="Italic"
                    Foreground="{StaticResource TextMutedBrush}"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"/>
            </StackPanel>

            <ProgressBar
                x:Name="LoadingProgressBar"
                Grid.Column="1"
                Margin="16,0"
                Visibility="Collapsed"
                IsIndeterminate="True"
                VerticalAlignment="Center"/>

            <Button
                x:Name="RefreshButton"
                Grid.Column="2"
                Width="100"
                Content="Refresh"
                Click="RefreshButton_Click"/>
        </Grid>

        <!-- State machines -->
        <Border
            Grid.Row="1"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource SurfaceBrush}"
            Effect="{StaticResource CardShadowEffect}"
            Padding="8">

            <DataGrid
                x:Name="StateMachinesGrid"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserSortColumns="False"
                HeadersVisibility="Column"
                SelectionMode="Single"
                SelectionUnit="FullRow"
                VirtualizingPanel.ScrollUnit="Pixel"
                RowHeight="36"
                MouseDoubleClick="StateMachinesGrid_MouseDoubleClick">

                <DataGrid.Columns>
                    <DataGridTextColumn
                        Header="State Machine"
                        Binding="{Binding Name}"
                        SortMemberPath="Name"
                        Width="*"/>

                    <DataGridTextColumn
                        Header="Type"
                        Binding="{Binding Type}"
                        SortMemberPath="Type"
                        Width="Auto"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>

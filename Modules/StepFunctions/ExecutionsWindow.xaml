<Window
    x:Class="KubaToolKit.Modules.StepFunctions.ExecutionsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Executions"
    Width="1000"
    Height="650"
    MinWidth="700"
    MinHeight="400"
    WindowStartupLocation="CenterOwner"
    Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock
                    x:Name="StateMachineNameTextBlock"
                    FontWeight="Bold"
                    FontSize="15"
                    Foreground="{StaticResource TextPrimaryBrush}"/>

                <TextBlock
                    Text="(double-click an execution for its event history, or a header to sort)"
                    FontSize="11"
                    FontStyle="Italic"
                    Foreground="{StaticResource TextMutedBrush}"
                    Margin="0,2,0,0"/>

                <TextBlock
                    x:Name="ExpressHintTextBlock"
                    Text="EXPRESS : liste reconstruite depuis CloudWatch Logs (7 derniers jours, nécessite la journalisation activée)"
                    FontSize="11"
                    FontStyle="Italic"
                    Foreground="{StaticResource TextMutedBrush}"
                    Margin="0,2,0,0"
                    Visibility="Collapsed"/>
            </StackPanel>

            <ProgressBar
                x:Name="LoadingProgressBar"
                Grid.Column="1"
                Margin="16,0"
                Visibility="Collapsed"
                IsIndeterminate="True"
                VerticalAlignment="Center"/>

            <Button
                x:Name="RefreshButton"
                Grid.Column="2"
                Width="100"
                Content="Refresh"
                Click="RefreshButton_Click"/>
        </Grid>

        <!-- Executions -->
        <Border
            Grid.Row="1"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMedium}"
            Background="{StaticResource SurfaceBrush}"
            Effect="{StaticResource CardShadowEffect}"
            Padding="{StaticResource CardPadding}">

            <DataGrid
                x:Name="ExecutionsGrid"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserSortColumns="False"
                HeadersVisibility="Column"
                HorizontalScrollBarVisibility="Auto"
                SelectionMode="Single"
                SelectionUnit="FullRow"
                VirtualizingPanel.ScrollUnit="Pixel"
                RowHeight="36"
                MouseDoubleClick="ExecutionsGrid_MouseDoubleClick">

                <DataGrid.Columns>
                    <DataGridTextColumn
                        Header="Execution"
                        Binding="{Binding Name}"
                        SortMemberPath="Name"
                        Width="Auto"/>

                    <DataGridTemplateColumn
                        Header="Status"
                        SortMemberPath="Status"
                        Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border
                                    Padding="10,4"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"
                                    Background="{Binding StatusBackground}">
                                    <TextBlock
                                        Text="{Binding Status}"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn
                        Header="Start"
                        Binding="{Binding StartDisplay}"
                        SortMemberPath="StartDate"
                        Width="Auto"/>

                    <DataGridTextColumn
                        Header="Stop"
                        Binding="{Binding StopDisplay}"
                        SortMemberPath="StopDate"
                        Width="Auto"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>

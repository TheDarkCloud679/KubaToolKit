<Window
    x:Class="KubaToolKit.Modules.StepFunctions.ExecutionEventsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Execution Events"
    Width="1100"
    Height="700"
    MinWidth="800"
    MinHeight="400"
    WindowStartupLocation="CenterOwner"
    Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock
                    x:Name="ExecutionNameTextBlock"
                    FontWeight="Bold"
                    FontSize="15"
                    Foreground="{StaticResource TextPrimaryBrush}"/>

                <TextBlock
                    Text="(double-click an event to view its formatted request/details, or a header to sort)"
                    FontSize="11"
                    FontStyle="Italic"
                    Foreground="{StaticResource TextMutedBrush}"
                    Margin="0,2,0,0"/>
            </StackPanel>

            <ProgressBar
                x:Name="LoadingProgressBar"
                Grid.Column="1"
                Margin="16,0"
                Visibility="Collapsed"
                IsIndeterminate="True"
                VerticalAlignment="Center"/>

            <Button
                x:Name="RefreshButton"
                Grid.Column="2"
                Width="100"
                Content="Refresh"
                Click="RefreshButton_Click"/>
        </Grid>

        <!-- Events -->
        <Border
            Grid.Row="1"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource SurfaceBrush}"
            Effect="{StaticResource CardShadowEffect}"
            Padding="8">

            <DataGrid
                x:Name="EventsGrid"
                AutoGenerateColumns="False"
                IsReadOnly="True"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserSortColumns="False"
                HeadersVisibility="Column"
                SelectionMode="Single"
                SelectionUnit="FullRow"
                VirtualizingPanel.ScrollUnit="Pixel"
                RowHeight="32"
                MouseDoubleClick="EventsGrid_MouseDoubleClick">

                <DataGrid.Columns>
                    <DataGridTextColumn
                        Header="ID"
                        Binding="{Binding Id}"
                        SortMemberPath="Id"
                        Width="Auto"/>

                    <DataGridTextColumn
                        Header="Type"
                        Binding="{Binding Type}"
                        SortMemberPath="Type"
                        Width="Auto"/>

                    <DataGridTextColumn
                        Header="Step"
                        Binding="{Binding Step}"
                        SortMemberPath="Step"
                        Width="Auto"/>

                    <DataGridTextColumn
                        Header="Resource"
                        Binding="{Binding Resource}"
                        SortMemberPath="Resource"
                        Width="*"/>

                    <DataGridTextColumn
                        Header="Timestamp"
                        Binding="{Binding TimestampDisplay}"
                        SortMemberPath="Timestamp"
                        Width="Auto"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>

<UserControl
    x:Class="KubaToolKit.Modules.S3Explorer.S3ExplorerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Bucket -->
        <StackPanel Orientation="Horizontal">

            <TextBlock
        Text="Bucket"
        FontWeight="SemiBold"
        VerticalAlignment="Center"
        Margin="0,0,8,0"/>

            <ComboBox
        x:Name="BucketCombo"
        Width="350"
        Height="28"
        SelectionChanged="BucketCombo_SelectionChanged"/>

        </StackPanel>
        <Grid
Grid.Row="1"
Margin="6,4,6,6">

            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Ligne barre -->
            <Grid Grid.Row="0">

                <!-- Barre -->
                <ProgressBar
    x:Name="SearchProgressBar"
    Height="6"
    Minimum="0"
    Maximum="100"
    Value="0"
    VerticalAlignment="Center"
    Margin="0,0,90,0"
    Visibility="Collapsed"
    Foreground="#4CAF50"
    Background="#D9D9D9"/>

                <!-- Pourcentage -->
                <TextBlock
    x:Name="S3LoadingText"
    HorizontalAlignment="Center"
    VerticalAlignment="Center"
    FontSize="10"
    FontWeight="SemiBold"
    Foreground="Black"
    Visibility="Collapsed"
    Text="0%"/>

                <!-- Cancel -->
                <Button
    x:Name="CancelDownloadButton"
    Width="80"
    Height="24"
    Content="Cancel"
    HorizontalAlignment="Right"
    VerticalAlignment="Center"
    Visibility="Collapsed"
    Click="CancelDownloadButton_Click"/>
            </Grid>

            <!-- Queue -->
            <TextBlock
                x:Name="S3QueueText"
                Grid.Row="1"
                Margin="0,4,0,0"
                HorizontalAlignment="Center"
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="#606060"
                TextWrapping="NoWrap"
                TextTrimming="CharacterEllipsis"
                Visibility="Collapsed"/>
        </Grid>

        <!-- Main split -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Tree -->
            <Border
        BorderBrush="#DADADA"
        BorderThickness="1"
        Padding="8">
                <TreeView
                    x:Name="S3TreeView"
                    SelectedItemChanged="S3TreeView_SelectedItemChanged">
                    <TreeView.Resources>
                        <ContextMenu x:Key="S3FolderMenu">
                            <MenuItem
                                Header="Search from here"
                                Click="S3SearchFromHere_Click"/>
                            <MenuItem
                                Header="Clear search scope"
                                Click="S3ClearSearchScope_Click"/>
                        </ContextMenu>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style
                                TargetType="TreeViewItem">
                            <EventSetter
                                Event="Expanded"
                                Handler="S3TreeViewItem_Expanded"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate
                            ItemsSource="{Binding Children}">
                            <StackPanel
                                Orientation="Horizontal"
                                Margin="0,1,0,1"
                                ContextMenu="{StaticResource S3FolderMenu}">
                                <TextBlock
                                    Text="├─"
                                    Foreground="#909090"
                                    FontFamily="Consolas"
                                    Margin="0,0,4,0"
                                    VerticalAlignment="Center"/>
                                <Border
Padding="2">

                                    <Border.Style>

                                        <Style TargetType="Border">

                                            <Setter
        Property="Background"
        Value="Transparent"/>

                                            <Style.Triggers>

                                                <DataTrigger
            Binding="{Binding IsSearchRoot}"
            Value="True">

                                                    <Setter
                        Property="Background"
                Value="#C8CDD4"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border
Padding="2">

                                        <Border.Style>

                                            <Style TargetType="Border">

                                                <Setter
        Property="Background"
        Value="Transparent"/>

                                                <Style.Triggers>

                                                    <DataTrigger
            Binding="{Binding IsSearchRoot}"
            Value="True">

                                                        <Setter
                Property="Background"
                Value="#C8CDD4"/>

                                                    </DataTrigger>

                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock
                                            Text="{Binding Name}"
                                            VerticalAlignment="Center"/>
                                    </Border>
                                </Border>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>

            <!-- Splitter -->
            <GridSplitter
                Grid.Column="1"
                Width="8"
                HorizontalAlignment="Stretch"/>

            <!-- Right panel -->
            <Border
Grid.Column="2"
BorderBrush="#DADADA"
BorderThickness="1"
Padding="8">

                <Grid>

                    <DataGrid
x:Name="S3FilesGrid"
AutoGenerateColumns="False"
IsReadOnly="True"
CanUserAddRows="False"
CanUserDeleteRows="False"
HeadersVisibility="Column"
SelectionMode="Extended"
SelectionUnit="FullRow"
AllowDrop="True"
Drop="S3FilesGrid_Drop"
DragOver="S3FilesGrid_DragOver"
DragLeave="S3FilesGrid_DragLeave"
MouseDoubleClick="S3FilesGrid_DoubleClick">

                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Open" Click="S3OpenFile_Click"/>
                                <Separator/>
                                <MenuItem Header="Download" Click="S3DownloadFile_Click"/>
                                <MenuItem Header="Rename" Click="S3RenameFile_Click"/>
                                <MenuItem Header="Delete" Click="S3DeleteFile_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>

                        <DataGrid.Columns>
                            <DataGridTextColumn
            Header="Name"
            Binding="{Binding Name}"
            Width="*"/>

                            <DataGridTextColumn
            Header="Size"
            Binding="{Binding SizeDisplay}"
            Width="100"/>

                            <DataGridTextColumn
            Header="Last Modified"
            Binding="{Binding LastModified}"
            Width="180"/>
                        </DataGrid.Columns>

                    </DataGrid>

                    <Border
x:Name="S3DropOverlay"
Visibility="Collapsed"
Background="#66000000"
BorderBrush="#707070"
BorderThickness="3"
CornerRadius="6"
IsHitTestVisible="False">

                        <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Center">

                            <TextBlock
            Text="+"
            FontSize="120"
            FontWeight="Light"
            Foreground="#E0E0E0"
            HorizontalAlignment="Center"/>

                            <TextBlock
            Text="Upload file(s)"
            FontSize="28"
            FontWeight="SemiBold"
            Foreground="#E0E0E0"
            HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<UserControl
    x:Class="KubaToolKit.Modules.S3Explorer.S3ExplorerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Bucket -->
        <Border
            Padding="14,10"
            Margin="0,0,0,10"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource SurfaceBrush}"
            Effect="{StaticResource CardShadowEffect}">
            <StackPanel Orientation="Horizontal">

                <TextBlock
            Text="Bucket"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextSecondaryBrush}"
            VerticalAlignment="Center"
            Margin="0,0,10,0"/>

                <ComboBox
            x:Name="BucketCombo"
            Width="350"
            SelectionChanged="BucketCombo_SelectionChanged"/>

            </StackPanel>
        </Border>
        <Grid
Grid.Row="1"
Margin="0,0,0,10">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Ligne barre -->
            <Grid Grid.Row="0">

                <!-- Barre -->
                <ProgressBar
    x:Name="SearchProgressBar"
    Minimum="0"
    Maximum="100"
    Value="0"
    VerticalAlignment="Center"
    Margin="0,0,90,0"
    Visibility="Collapsed"/>

                <!-- Pourcentage -->
                <TextBlock
    x:Name="S3LoadingText"
    HorizontalAlignment="Center"
    VerticalAlignment="Center"
    FontSize="10"
    FontWeight="SemiBold"
    Foreground="{StaticResource TextPrimaryBrush}"
    Visibility="Collapsed"
    Text="0%"/>

                <!-- Cancel -->
                <Button
    x:Name="CancelDownloadButton"
    Width="80"
    Height="24"
    Content="Cancel"
    HorizontalAlignment="Right"
    VerticalAlignment="Center"
    Visibility="Collapsed"
    Click="CancelDownloadButton_Click"/>
            </Grid>

            <!-- Queue -->
            <TextBlock
                x:Name="S3QueueText"
                Grid.Row="1"
                Margin="0,6,0,0"
                HorizontalAlignment="Center"
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextSecondaryBrush}"
                TextWrapping="NoWrap"
                TextTrimming="CharacterEllipsis"
                Visibility="Collapsed"/>
        </Grid>

        <!-- Main split -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Tree -->
            <Border
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="8"
        Background="{StaticResource SurfaceBrush}"
        Effect="{StaticResource CardShadowEffect}"
        Padding="10">
                <TreeView
                    x:Name="S3TreeView"
                    SelectedItemChanged="S3TreeView_SelectedItemChanged">
                    <TreeView.Resources>
                        <ContextMenu x:Key="S3FolderMenu">
                            <MenuItem
                                Header="Search from here"
                                Click="S3SearchFromHere_Click"/>
                            <MenuItem
                                Header="Clear search scope"
                                Click="S3ClearSearchScope_Click"/>
                        </ContextMenu>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style
                                TargetType="TreeViewItem">
                            <EventSetter
                                Event="Expanded"
                                Handler="S3TreeViewItem_Expanded"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate
                            ItemsSource="{Binding Children}">
                            <Border
                                Padding="6,3"
                                Margin="0,1,0,1"
                                CornerRadius="4"
                                ContextMenu="{StaticResource S3FolderMenu}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSearchRoot}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock
                                    Text="{Binding Name}"
                                    VerticalAlignment="Center"/>
                            </Border>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>

            <!-- Splitter -->
            <GridSplitter
                Grid.Column="1"
                Width="10"
                HorizontalAlignment="Stretch"/>

            <!-- Right panel -->
            <Border
Grid.Column="2"
BorderBrush="{StaticResource BorderBrush}"
BorderThickness="1"
CornerRadius="8"
Background="{StaticResource SurfaceBrush}"
Effect="{StaticResource CardShadowEffect}"
Padding="10">

                <Grid>

                    <DataGrid
x:Name="S3FilesGrid"
AutoGenerateColumns="False"
IsReadOnly="True"
CanUserAddRows="False"
CanUserDeleteRows="False"
HeadersVisibility="Column"
HorizontalScrollBarVisibility="Auto"
SelectionMode="Extended"
SelectionUnit="FullRow"
AllowDrop="True"
Drop="S3FilesGrid_Drop"
DragOver="S3FilesGrid_DragOver"
DragLeave="S3FilesGrid_DragLeave"
MouseDoubleClick="S3FilesGrid_DoubleClick">

                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Open" Click="S3OpenFile_Click"/>
                                <Separator/>
                                <MenuItem Header="Download" Click="S3DownloadFile_Click"/>
                                <MenuItem Header="Rename" Click="S3RenameFile_Click"/>
                                <MenuItem Header="Delete" Click="S3DeleteFile_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>

                        <DataGrid.Columns>
                            <DataGridTextColumn
            Header="Name"
            Binding="{Binding Name}"
            Width="*"/>

                            <DataGridTextColumn
            Header="Size"
            Binding="{Binding SizeDisplay}"
            Width="Auto"/>

                            <DataGridTextColumn
            Header="Last Modified"
            Binding="{Binding LastModified}"
            Width="Auto"/>
                        </DataGrid.Columns>

                    </DataGrid>

                    <Border
x:Name="S3DropOverlay"
Visibility="Collapsed"
Background="#E6103A66"
BorderBrush="{StaticResource AccentBrush}"
BorderThickness="2"
CornerRadius="8"
IsHitTestVisible="False">

                        <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Center">

                            <TextBlock
            Text="+"
            FontSize="100"
            FontWeight="Light"
            Foreground="White"
            HorizontalAlignment="Center"/>

                            <TextBlock
            Text="Drop to upload file(s)"
            FontSize="24"
            FontWeight="SemiBold"
            Foreground="White"
            HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<UserControl
    x:Class="KubaToolKit.Modules.CloudTrail.CloudTrailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="ResultsPanel">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Progress -->
        <Grid
            Grid.Row="0"
            Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock
                x:Name="ProgressTextBlock"
                Grid.Column="0"
                Margin="2,0,0,0"
                VerticalAlignment="Center"
                FontSize="11"
                Foreground="{StaticResource TextSecondaryBrush}"/>
            <ProgressBar
                x:Name="SearchProgressBar"
                Grid.Column="1"
                Margin="16,0,4,0"
                Minimum="0"
                Maximum="100"
                Value="0"
                VerticalAlignment="Center"/>
        </Grid>

        <!-- Results, grouped by AWS service (EventSource) -->
        <Border
            Grid.Row="1"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMedium}"
            Background="{StaticResource SurfaceBrush}"
            Effect="{StaticResource CardShadowEffect}"
            Padding="{StaticResource CardPadding}">
            <ScrollViewer
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled"
                CanContentScroll="True">
                <ItemsControl x:Name="EventsGroupedItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander
                                IsExpanded="False"
                                Margin="0,0,0,8">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            Text="{Binding EventSource}"
                                            FontWeight="Bold"
                                            FontSize="13"
                                            Foreground="{StaticResource AccentBrush}"/>
                                        <Border
                                            Margin="8,0,0,0"
                                            Padding="7,1"
                                            CornerRadius="8"
                                            Background="{StaticResource AccentSoftBrush}"
                                            VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="{Binding Count, StringFormat=({0} events)}"/>
                                        </Border>
                                    </StackPanel>
                                </Expander.Header>
                                <DataGrid
                                    ItemsSource="{Binding Events}"
                                    AutoGenerateColumns="False"
                                    IsReadOnly="True"
                                    HeadersVisibility="Column"
                                    CanUserAddRows="False"
                                    CanUserDeleteRows="False"
                                    Margin="0,6,0,0"
                                    MaxHeight="350"
                                    MouseDoubleClick="EventsDataGrid_DoubleClick"
                                    HorizontalScrollBarVisibility="Visible">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Header="Timestamp"
                                            Binding="{Binding Timestamp}"
                                            Width="Auto"/>
                                        <DataGridTextColumn
                                            Header="Event"
                                            Binding="{Binding EventName}"
                                            Width="Auto"/>
                                        <DataGridTextColumn
                                            Header="User"
                                            Binding="{Binding Username}"
                                            Width="Auto"/>
                                        <DataGridTemplateColumn
                                            Header="Resources"
                                            Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock
                                                        Text="{Binding Resources}"
                                                        TextWrapping="Wrap"
                                                        TextTrimming="CharacterEllipsis"
                                                        VerticalAlignment="Center"
                                                        MaxHeight="42"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

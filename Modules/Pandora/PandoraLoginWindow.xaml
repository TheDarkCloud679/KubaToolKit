<Window
    x:Class="KubaToolKit.Modules.Pandora.PandoraLoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="Pandora - Connexion"
    Width="1200"
    Height="800"
    MinWidth="600"
    MinHeight="450"
    WindowState="Maximized"
    WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- En haut et bien visible plutôt qu'en bas, où le contenu de la
             page Pandora (souvent longue) pouvait le repousser hors champ
             malgré la fenêtre maximisée. -->
        <Border
            Grid.Row="0"
            Background="{StaticResource AccentBrush}"
            Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    TextWrapping="Wrap"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextOnAccentBrush}"
                    Text="Connecte-toi (SSO puis, si demandé, le formulaire Pandora). Une fois le tableau de bord Pandora réellement affiché ci-dessous, clique sur Continuer."/>

                <Button
                    x:Name="ContinueButton"
                    Grid.Column="1"
                    Margin="16,0,0,0"
                    Padding="18,6"
                    FontWeight="Bold"
                    Content="Continuer"
                    Click="ContinueButton_Click"/>
            </Grid>
        </Border>

        <wv2:WebView2 x:Name="WebView" Grid.Row="1"/>
    </Grid>
</Window>

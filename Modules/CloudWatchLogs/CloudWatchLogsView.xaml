<UserControl
    x:Class="KubaToolKit.Modules.CloudWatchLogs.CloudWatchLogsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit">
    <Grid>
        <Grid.RowDefinitions>

            <!-- Log groups -->
            <RowDefinition Height="300"
                   MinHeight="80"/>

            <!-- Splitter -->
            <RowDefinition Height="6"/>

            <!-- Debug -->
            <RowDefinition Height="150"
               MinHeight="80"/>

            <!-- Splitter -->
            <RowDefinition Height="6"/>

            <!-- Results -->
            <RowDefinition Height="*"
                   MinHeight="150"/>
        </Grid.RowDefinitions>

        <!-- ===================================================== -->
        <!-- LOG GROUPS -->
        <!-- ===================================================== -->

        <Border
            x:Name="LogGroupsPanel"
            Grid.Row="0"
            Padding="12"
            Margin="0,0,0,8"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource SurfaceBrush}"
            Effect="{StaticResource CardShadowEffect}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    FontWeight="Bold"
                    FontSize="13"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="Log Groups"/>
                <CheckBox
                    x:Name="SearchAllLogsCheckBox"
                    Margin="0,18,0,10"
                    Content="Search in all log groups"
                    FontWeight="SemiBold"
                    Checked="SearchAllLogsCheckBox_Changed"
                    Unchecked="SearchAllLogsCheckBox_Changed" Grid.RowSpan="2"/>
                <TreeView
    x:Name="LogGroupsTreeView"
    Grid.Row="2"
    PreviewMouseWheel="LogGroupsTreeView_PreviewMouseWheel">

                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate
        ItemsSource="{Binding Children}">

                            <StackPanel
            Orientation="Horizontal">

                                <CheckBox
                IsChecked="{Binding IsChecked, Mode=TwoWay}"
                VerticalAlignment="Center"/>

                                <TextBlock
                Text="{Binding Name}"
                Margin="6,0,0,0"
                VerticalAlignment="Center"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>
        </Border>
        <GridSplitter
               x:Name="LogGroupSplitter"
               Grid.Row="1"
               Height="6"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Center"
               ResizeBehavior="PreviousAndNext"
               ResizeDirection="Rows"/>

        <!-- ===================================================== -->
        <!-- DEBUG MODE -->
        <!-- ===================================================== -->

        <Border
           x:Name="DebugModePanel"
           Grid.Row="2"
           Margin="0,0,0,8"
           Padding="12"
           BorderBrush="{StaticResource BorderBrush}"
           BorderThickness="1"
           CornerRadius="8"
           Background="{StaticResource SurfaceBrush}"
           Effect="{StaticResource CardShadowEffect}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <CheckBox
                    Grid.Row="0"
                    x:Name="DebugModeCheckBox"
                    Content="Debug mode"
                    FontWeight="SemiBold"
                    Checked="DebugModeCheckBox_Checked"
                    Unchecked="DebugModeCheckBox_Unchecked"/>
                <Grid
                   Grid.Row="1"
                   x:Name="DebugPanel"
                   Visibility="Collapsed"
                   Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,6"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="CloudWatch Logs Insights Query"/>
                    <Border
                        Grid.Row="1"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="4">
                        <avalonedit:TextEditor
                            x:Name="QueryEditorTextBox"
                            MinHeight="120"
                            FontFamily="Cascadia Code, Consolas"
                            FontSize="13"
                            ShowLineNumbers="True"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto"/>
                    </Border>
                    <Grid
                      Grid.Row="2"
                      Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button
                            Grid.Column="0"
                            Width="120"
                            Content="Preview Query"
                            Click="PreviewQuery_Click"/>
                        <Button
                            Grid.Column="2"
                            Width="120"
                            Content="Copy Query"
                            Click="CopyQuery_Click"/>
                        <Button
                            Grid.Column="4"
                            Width="150"
                            Style="{StaticResource AccentButtonStyle}"
                            Content="Use Custom Query"
                            Click="UseCustomQuery_Click"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
        <GridSplitter
               x:Name="DebugSplitter"
               Grid.Row="3"
               Height="6"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Center"
               ResizeBehavior="PreviousAndNext"
               ResizeDirection="Rows"/>

        <!-- ===================================================== -->
        <!-- RESULTS -->
        <!-- ===================================================== -->

        <Grid Grid.Row="4"
            x:Name="ResultsPanel">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Progress -->
            <Grid
              Grid.Row="0"
              Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="ProgressTextBlock"
                    Grid.Column="0"
                    Margin="2,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{StaticResource TextSecondaryBrush}"/>
                <ProgressBar
                    x:Name="SearchProgressBar"
                    Grid.Column="1"
                    Margin="16,0,4,0"
                    Minimum="0"
                    Maximum="100"
                    Value="0"
                    VerticalAlignment="Center"/>
            </Grid>

            <!-- Results -->
            <Border
                 Grid.Row="1"
                 BorderBrush="{StaticResource BorderBrush}"
                 BorderThickness="1"
                 CornerRadius="8"
                 Background="{StaticResource SurfaceBrush}"
                 Effect="{StaticResource CardShadowEffect}"
                 Padding="8">
                <ScrollViewer
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        CanContentScroll="True">
                    <ItemsControl
                       x:Name="LogsGroupedItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander
                                    IsExpanded="False"
                                    Margin="0,0,0,8">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                Text="{Binding LogGroup}"
                                                FontWeight="Bold"
                                                FontSize="13"
                                                Foreground="{StaticResource AccentBrush}"/>
                                            <Border
                                                Margin="8,0,0,0"
                                                Padding="7,1"
                                                CornerRadius="8"
                                                Background="{StaticResource AccentSoftBrush}"
                                                VerticalAlignment="Center">
                                                <TextBlock
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Text="{Binding Count, StringFormat=({0} logs)}"/>
                                            </Border>
                                        </StackPanel>
                                    </Expander.Header>
                                    <DataGrid
                                            ItemsSource="{Binding Logs}"
                                            AutoGenerateColumns="False"
                                            IsReadOnly="True"
                                            HeadersVisibility="Column"
                                            CanUserAddRows="False"
                                            CanUserDeleteRows="False"
                                            Margin="0,6,0,0"
                                            MaxHeight="350"
                                            MouseDoubleClick="LogsDataGrid_DoubleClick"
                                            HorizontalScrollBarVisibility="Visible">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn
                                                Header="Timestamp"
                                                Binding="{Binding Timestamp}"
                                                Width="180"/>
                                            <DataGridTemplateColumn
                                                    Header="Message"
                                                    Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock
                                                            Text="{Binding Message}"
                                                            TextWrapping="Wrap"
                                                            TextTrimming="CharacterEllipsis"
                                                            VerticalAlignment="Center"
                                                            MaxHeight="42"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>

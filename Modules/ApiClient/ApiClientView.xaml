<UserControl
    x:Class="KubaToolKit.Modules.ApiClient.ApiClientView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Collections -->
        <Border
            Grid.Column="0"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource SurfaceBrush}"
            Effect="{StaticResource CardShadowEffect}"
            Padding="10">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        Text="Collections"
                        FontWeight="Bold"
                        FontSize="13"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        ToolTip="Double-clic : trier par nom"
                        MouseLeftButtonDown="CollectionsHeader_MouseLeftButtonDown"/>

                    <Button
                        Grid.Column="1"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Margin="4,0,0,0"
                        ToolTip="Nouvelle collection"
                        Content="+"
                        Click="NewCollection_Click"/>

                    <Button
                        Grid.Column="2"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Margin="4,0,0,0"
                        ToolTip="Ouvrir le dossier des collections/environnements"
                        Content="📂"
                        Click="OpenCollectionsFolder_Click"/>

                    <Button
                        Grid.Column="3"
                        Width="28"
                        Height="28"
                        Padding="0"
                        Margin="4,0,0,0"
                        ToolTip="Recharger depuis le disque"
                        Content="⟳"
                        Click="ReloadCollections_Click"/>
                </Grid>

                <TreeView
                    x:Name="CollectionsTreeView"
                    Grid.Row="1"
                    BorderThickness="0"
                    Background="Transparent"
                    MouseDoubleClick="CollectionsTreeView_MouseDoubleClick"
                    PreviewMouseRightButtonDown="CollectionsTreeView_PreviewMouseRightButtonDown">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock
                                Text="{Binding DisplayText}"
                                TextTrimming="CharacterEllipsis"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                    <TreeView.ContextMenu>
                        <ContextMenu Opened="CollectionsContextMenu_Opened">
                            <MenuItem
                                x:Name="AddRequestMenuItem"
                                Header="Nouvelle requête (depuis l'éditeur)"
                                Click="AddRequestToCollection_Click"/>
                            <MenuItem
                                x:Name="AddFolderMenuItem"
                                Header="Nouveau dossier"
                                Click="AddFolder_Click"/>
                            <Separator/>
                            <MenuItem
                                x:Name="UpdateRequestMenuItem"
                                Header="Mettre à jour depuis l'éditeur"
                                Click="UpdateRequestFromEditor_Click"/>
                            <MenuItem
                                x:Name="FavoriteMenuItem"
                                Header="☆ Ajouter aux favoris"
                                Click="ToggleFavorite_Click"/>
                            <MenuItem
                                x:Name="RenameMenuItem"
                                Header="Renommer"
                                Click="RenameNode_Click"/>
                            <MenuItem
                                x:Name="FolderAuthMenuItem"
                                Header="Modifier l'authentification"
                                Click="EditFolderAuth_Click"/>
                            <Separator/>
                            <MenuItem
                                x:Name="DeleteMenuItem"
                                Header="Supprimer"
                                Click="DeleteNode_Click"/>
                        </ContextMenu>
                    </TreeView.ContextMenu>
                </TreeView>
            </Grid>
        </Border>

        <GridSplitter
            Grid.Column="1"
            Width="6"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            ResizeBehavior="PreviousAndNext"
            ResizeDirection="Columns"/>

        <!-- Request / Response -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition x:Name="RequestConfigRow" Height="280" MinHeight="60"/>
                <RowDefinition Height="6"/>
                <RowDefinition x:Name="ResponseRow" Height="*" MinHeight="120"/>
            </Grid.RowDefinitions>

            <!-- Method / URL / Environment / Send -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>

                <ComboBox
                    x:Name="MethodCombo"
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    SelectedIndex="0"
                    SelectionChanged="MethodCombo_SelectionChanged">
                    <ComboBoxItem Content="GET"/>
                    <ComboBoxItem Content="POST"/>
                    <ComboBoxItem Content="PUT"/>
                    <ComboBoxItem Content="PATCH"/>
                    <ComboBoxItem Content="DELETE"/>
                    <ComboBoxItem Content="HEAD"/>
                    <ComboBoxItem Content="OPTIONS"/>
                </ComboBox>

                <TextBox
                    x:Name="UrlTextBox"
                    Grid.Column="1"
                    VerticalContentAlignment="Center"
                    Text="https://"
                    KeyDown="UrlTextBox_KeyDown"/>

                <ComboBox
                    x:Name="EnvironmentCombo"
                    Grid.Column="2"
                    Margin="8,0,0,0"
                    DisplayMemberPath="Name"
                    ToolTip="Environnement (variables {{clé}})"/>

                <Button
                    Grid.Column="3"
                    Width="28"
                    Height="28"
                    Padding="0"
                    Margin="6,0,0,0"
                    ToolTip="Ajouter un environnement (ouvre le dossier)"
                    Content="+"
                    Click="AddEnvironment_Click"/>

                <Button
                    Grid.Column="4"
                    Width="28"
                    Height="28"
                    Padding="0"
                    Margin="4,0,0,0"
                    ToolTip="Modifier les variables de l'environnement sélectionné"
                    Content="✎"
                    Click="EditEnvironment_Click"/>

                <Button
                    Grid.Column="5"
                    Width="28"
                    Height="28"
                    Padding="0"
                    Margin="4,0,0,0"
                    ToolTip="Recharger les environnements"
                    Content="⟳"
                    Click="ReloadEnvironments_Click"/>

                <Button
                    x:Name="SendButton"
                    Grid.Column="6"
                    Margin="8,0,0,0"
                    Style="{StaticResource AccentButtonStyle}"
                    Content="Send"
                    Click="SendButton_Click"/>
            </Grid>

            <!-- Request config: Auth / Headers / Body -->
            <Border
                Grid.Row="1"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Background="{StaticResource SurfaceBrush}"
                Effect="{StaticResource CardShadowEffect}"
                Padding="12">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Params -->
                        <Expander
                            Header="Params"
                            IsExpanded="False"
                            Margin="0,0,0,10">
                            <StackPanel Margin="0,10,0,0">
                                <Button
                                    HorizontalAlignment="Right"
                                    Width="26"
                                    Height="26"
                                    Padding="0"
                                    Margin="0,0,0,6"
                                    ToolTip="Ajouter une ligne"
                                    Content="+"
                                    Click="AddParamRow_Click"/>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="180" MinHeight="60"/>
                                        <RowDefinition Height="6"/>
                                    </Grid.RowDefinitions>

                                    <DataGrid
                                        x:Name="ParamsGrid"
                                        Grid.Row="0"
                                        AutoGenerateColumns="False"
                                        CanUserAddRows="True"
                                        CanUserDeleteRows="True"
                                        HeadersVisibility="Column"
                                        HorizontalScrollBarVisibility="Auto"
                                        VerticalScrollBarVisibility="Auto"
                                        RowHeight="38"
                                        LostFocus="ParamsGrid_LostFocus">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn
                                                Header="On"
                                                Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                Width="Auto"/>

                                            <DataGridTextColumn
                                                Header="Key"
                                                Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                                CellStyle="{StaticResource EditableDataGridCellStyle}"
                                                Width="2*"
                                                MinWidth="160">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="ToolTip" Value="{Binding Key}"/>
                                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn
                                                Header="Value"
                                                Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                CellStyle="{StaticResource EditableDataGridCellStyle}"
                                                Width="3*"
                                                MinWidth="200">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="ToolTip" Value="{Binding Value}"/>
                                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTemplateColumn Width="34">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button
                                                            Width="24"
                                                            Height="24"
                                                            Padding="0"
                                                            ToolTip="Supprimer cette ligne"
                                                            Content="✕"
                                                            Click="DeleteHeaderItemRow_Click"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <GridSplitter
                                        Grid.Row="1"
                                        Height="6"
                                        HorizontalAlignment="Stretch"
                                        ResizeBehavior="PreviousAndCurrent"
                                        ResizeDirection="Rows"
                                        ToolTip="Glisser pour redimensionner"/>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <!-- Auth -->
                        <Expander
                            Header="Auth"
                            IsExpanded="False"
                            Margin="0,0,0,10">
                            <StackPanel Margin="4,10,4,4">
                                <ComboBox
                                    x:Name="AuthTypeCombo"
                                    Width="220"
                                    HorizontalAlignment="Left"
                                    SelectedIndex="0"
                                    SelectionChanged="AuthTypeCombo_SelectionChanged">
                                    <ComboBoxItem Content="Inherit auth from parent"/>
                                    <ComboBoxItem Content="No Auth"/>
                                    <ComboBoxItem Content="Bearer Token"/>
                                    <ComboBoxItem Content="Basic Auth"/>
                                    <ComboBoxItem Content="API Key"/>
                                </ComboBox>

                                <TextBlock
                                    x:Name="InheritAuthPanel"
                                    Margin="0,10,0,0"
                                    TextWrapping="Wrap"
                                    FontSize="12"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="L'en-tête d'autorisation sera calculé à l'envoi à partir de l'authentification définie sur le dossier ou la collection parente (clic droit dessus &#8594; « Modifier l'authentification »)."/>

                                <StackPanel
                                    x:Name="BearerAuthPanel"
                                    Margin="0,10,0,0"
                                    Visibility="Collapsed">
                                    <TextBlock
                                        Text="Token"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Margin="0,0,0,4"/>
                                    <TextBox x:Name="BearerTokenTextBox" TextChanged="AuthField_Changed"/>
                                </StackPanel>

                                <StackPanel
                                    x:Name="BasicAuthPanel"
                                    Margin="0,10,0,0"
                                    Visibility="Collapsed">
                                    <TextBlock
                                        Text="Username"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Margin="0,0,0,4"/>
                                    <TextBox x:Name="BasicUsernameTextBox" Margin="0,0,0,8" TextChanged="AuthField_Changed"/>
                                    <TextBlock
                                        Text="Password"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Margin="0,0,0,4"/>
                                    <PasswordBox x:Name="BasicPasswordBox" PasswordChanged="AuthField_Changed"/>
                                </StackPanel>

                                <StackPanel
                                    x:Name="ApiKeyAuthPanel"
                                    Margin="0,10,0,0"
                                    Visibility="Collapsed">
                                    <TextBlock
                                        Text="Header Name"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Margin="0,0,0,4"/>
                                    <TextBox
                                        x:Name="ApiKeyNameTextBox"
                                        Text="X-API-Key"
                                        Margin="0,0,0,8"
                                        TextChanged="AuthField_Changed"/>
                                    <TextBlock
                                        Text="Value"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Margin="0,0,0,4"/>
                                    <TextBox x:Name="ApiKeyValueTextBox" TextChanged="AuthField_Changed"/>
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <!-- Headers -->
                        <Expander
                            Header="Headers"
                            IsExpanded="False"
                            Margin="0,0,0,10">
                            <StackPanel Margin="0,10,0,0">
                                <Button
                                    HorizontalAlignment="Right"
                                    Width="26"
                                    Height="26"
                                    Padding="0"
                                    Margin="0,0,0,6"
                                    ToolTip="Ajouter une ligne"
                                    Content="+"
                                    Click="AddHeaderRow_Click"/>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="220" MinHeight="60"/>
                                        <RowDefinition Height="6"/>
                                    </Grid.RowDefinitions>

                                    <DataGrid
                                        x:Name="HeadersGrid"
                                        Grid.Row="0"
                                        AutoGenerateColumns="False"
                                        CanUserAddRows="True"
                                        CanUserDeleteRows="True"
                                        HeadersVisibility="Column"
                                        HorizontalScrollBarVisibility="Auto"
                                        VerticalScrollBarVisibility="Auto"
                                        RowHeight="38"
                                        LostFocus="HeadersGrid_LostFocus">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn
                                                Header="On"
                                                Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                Width="Auto"/>

                                            <DataGridTextColumn
                                                Header="Key"
                                                Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                                CellStyle="{StaticResource EditableDataGridCellStyle}"
                                                Width="2*"
                                                MinWidth="160">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="ToolTip" Value="{Binding Key}"/>
                                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTextColumn
                                                Header="Value"
                                                Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                CellStyle="{StaticResource EditableDataGridCellStyle}"
                                                Width="3*"
                                                MinWidth="200">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="ToolTip" Value="{Binding Value}"/>
                                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>

                                            <DataGridTemplateColumn Width="34">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button
                                                            Width="24"
                                                            Height="24"
                                                            Padding="0"
                                                            ToolTip="Supprimer cette ligne"
                                                            Content="✕"
                                                            Click="DeleteHeaderItemRow_Click"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <GridSplitter
                                        Grid.Row="1"
                                        Height="6"
                                        HorizontalAlignment="Stretch"
                                        ResizeBehavior="PreviousAndCurrent"
                                        ResizeDirection="Rows"
                                        ToolTip="Glisser pour redimensionner"/>
                                </Grid>

                                <TextBlock
                                    x:Name="ToggleAutoHeadersText"
                                    Margin="0,10,0,6"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Cursor="Hand"
                                    Text="Masquer les en-têtes générés automatiquement"
                                    MouseLeftButtonDown="ToggleAutoHeaders_MouseLeftButtonDown"/>

                                <Grid x:Name="AutoHeadersGridContainer">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="200" MinHeight="60"/>
                                        <RowDefinition Height="6"/>
                                    </Grid.RowDefinitions>

                                    <DataGrid
                                        x:Name="AutoHeadersGrid"
                                        Grid.Row="0"
                                        IsReadOnly="True"
                                        AutoGenerateColumns="False"
                                        CanUserAddRows="False"
                                        CanUserDeleteRows="False"
                                        HeadersVisibility="Column"
                                        HorizontalScrollBarVisibility="Auto"
                                        VerticalScrollBarVisibility="Auto"
                                        RowHeight="34"
                                        Opacity="0.7"
                                        ToolTip="En-têtes ajoutés automatiquement par KubaToolKit à l'envoi ; non modifiables ici.">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn
                                                Header="Key"
                                                Binding="{Binding Key}"
                                                Width="2*"
                                                MinWidth="160"/>

                                            <DataGridTextColumn
                                                Header="Value"
                                                Binding="{Binding Value}"
                                                Width="3*"
                                                MinWidth="200"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <GridSplitter
                                        Grid.Row="1"
                                        Height="6"
                                        HorizontalAlignment="Stretch"
                                        ResizeBehavior="PreviousAndCurrent"
                                        ResizeDirection="Rows"
                                        ToolTip="Glisser pour redimensionner"/>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <!-- Body -->
                        <Expander
                            Header="Body"
                            IsExpanded="False">
                            <StackPanel Margin="0,10,0,0">

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <RadioButton
                                        x:Name="BodyNoneRadio"
                                        Content="none"
                                        GroupName="BodyMode"
                                        Checked="BodyMode_Checked"
                                        VerticalAlignment="Center"
                                        Margin="0,0,16,0"/>

                                    <RadioButton
                                        x:Name="BodyFormDataRadio"
                                        Content="form-data"
                                        GroupName="BodyMode"
                                        Checked="BodyMode_Checked"
                                        VerticalAlignment="Center"
                                        Margin="0,0,16,0"/>

                                    <RadioButton
                                        x:Name="BodyUrlEncodedRadio"
                                        Content="x-www-form-urlencoded"
                                        GroupName="BodyMode"
                                        Checked="BodyMode_Checked"
                                        VerticalAlignment="Center"
                                        Margin="0,0,16,0"/>

                                    <RadioButton
                                        x:Name="BodyRawRadio"
                                        Content="raw"
                                        GroupName="BodyMode"
                                        IsChecked="True"
                                        Checked="BodyMode_Checked"
                                        VerticalAlignment="Center"
                                        Margin="0,0,16,0"/>

                                    <RadioButton
                                        x:Name="BodyBinaryRadio"
                                        Content="binary"
                                        GroupName="BodyMode"
                                        Checked="BodyMode_Checked"
                                        VerticalAlignment="Center"
                                        Margin="0,0,16,0"/>

                                    <RadioButton
                                        x:Name="BodyGraphQlRadio"
                                        Content="GraphQL"
                                        GroupName="BodyMode"
                                        Checked="BodyMode_Checked"
                                        VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- none -->
                                <TextBlock
                                    x:Name="BodyNonePanel"
                                    Text="Cette requête n'a pas de body."
                                    FontStyle="Italic"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Visibility="Collapsed"/>

                                <!-- form-data / x-www-form-urlencoded (même grille, collection réassignée selon le mode) -->
                                <StackPanel
                                    x:Name="BodyFormPanel"
                                    Visibility="Collapsed">
                                    <Button
                                        HorizontalAlignment="Right"
                                        Width="26"
                                        Height="26"
                                        Padding="0"
                                        Margin="0,0,0,6"
                                        ToolTip="Ajouter une ligne"
                                        Content="+"
                                        Click="AddBodyFormRow_Click"/>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="220" MinHeight="60"/>
                                            <RowDefinition Height="6"/>
                                        </Grid.RowDefinitions>

                                        <DataGrid
                                            x:Name="BodyFormGrid"
                                            Grid.Row="0"
                                            AutoGenerateColumns="False"
                                            CanUserAddRows="True"
                                            CanUserDeleteRows="True"
                                            HeadersVisibility="Column"
                                            HorizontalScrollBarVisibility="Auto"
                                            VerticalScrollBarVisibility="Auto"
                                            RowHeight="38">
                                            <DataGrid.Columns>
                                                <DataGridCheckBoxColumn
                                                    Header="On"
                                                    Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="Auto"/>

                                                <DataGridTextColumn
                                                    Header="Key"
                                                    Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                                    CellStyle="{StaticResource EditableDataGridCellStyle}"
                                                    Width="2*"
                                                    MinWidth="160">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="ToolTip" Value="{Binding Key}"/>
                                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>

                                                <DataGridTextColumn
                                                    Header="Value"
                                                    Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                    CellStyle="{StaticResource EditableDataGridCellStyle}"
                                                    Width="3*"
                                                    MinWidth="200">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="ToolTip" Value="{Binding Value}"/>
                                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>

                                                <DataGridTemplateColumn Width="34">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button
                                                                Width="24"
                                                                Height="24"
                                                                Padding="0"
                                                                ToolTip="Supprimer cette ligne"
                                                                Content="✕"
                                                                Click="DeleteHeaderItemRow_Click"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <GridSplitter
                                            Grid.Row="1"
                                            Height="6"
                                            HorizontalAlignment="Stretch"
                                            ResizeBehavior="PreviousAndCurrent"
                                            ResizeDirection="Rows"
                                            ToolTip="Glisser pour redimensionner"/>
                                    </Grid>
                                </StackPanel>

                                <!-- raw -->
                                <StackPanel x:Name="BodyRawPanel">
                                    <ComboBox
                                        x:Name="RawContentTypeCombo"
                                        Width="140"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,8"
                                        SelectedIndex="1"
                                        SelectionChanged="RawContentTypeCombo_SelectionChanged">
                                        <ComboBoxItem Content="Text"/>
                                        <ComboBoxItem Content="JSON"/>
                                        <ComboBoxItem Content="JavaScript"/>
                                        <ComboBoxItem Content="HTML"/>
                                        <ComboBoxItem Content="XML"/>
                                    </ComboBox>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="220" MinHeight="80"/>
                                            <RowDefinition Height="6"/>
                                        </Grid.RowDefinitions>

                                        <TextBox
                                            x:Name="BodyTextBox"
                                            Grid.Row="0"
                                            AcceptsReturn="True"
                                            AcceptsTab="True"
                                            TextWrapping="NoWrap"
                                            VerticalScrollBarVisibility="Auto"
                                            HorizontalScrollBarVisibility="Auto"
                                            FontFamily="Cascadia Code, Consolas"
                                            FontSize="13"
                                            TextChanged="BodyTextBox_TextChanged"/>

                                        <GridSplitter
                                            Grid.Row="1"
                                            Height="6"
                                            HorizontalAlignment="Stretch"
                                            ResizeBehavior="PreviousAndCurrent"
                                            ResizeDirection="Rows"
                                            ToolTip="Glisser pour redimensionner"/>
                                    </Grid>
                                </StackPanel>

                                <!-- binary -->
                                <StackPanel
                                    x:Name="BodyBinaryPanel"
                                    Orientation="Horizontal"
                                    Visibility="Collapsed">
                                    <Button
                                        Padding="10,6"
                                        Margin="0,0,10,0"
                                        Content="Sélectionner un fichier"
                                        Click="SelectBinaryFile_Click"/>

                                    <TextBlock
                                        x:Name="BinaryFilePathText"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        TextTrimming="CharacterEllipsis"
                                        Text="Aucun fichier sélectionné"/>
                                </StackPanel>

                                <!-- GraphQL -->
                                <StackPanel
                                    x:Name="BodyGraphQlPanel"
                                    Visibility="Collapsed">
                                    <TextBlock
                                        Text="Query"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Margin="0,0,0,4"/>

                                    <TextBox
                                        x:Name="GraphQlQueryTextBox"
                                        AcceptsReturn="True"
                                        AcceptsTab="True"
                                        TextWrapping="NoWrap"
                                        VerticalScrollBarVisibility="Auto"
                                        HorizontalScrollBarVisibility="Auto"
                                        FontFamily="Cascadia Code, Consolas"
                                        FontSize="13"
                                        MinHeight="120"
                                        MaxHeight="200"
                                        Margin="0,0,0,10"
                                        TextChanged="GraphQlQueryTextBox_TextChanged"/>

                                    <TextBlock
                                        Text="Variables (JSON)"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Margin="0,0,0,4"/>

                                    <TextBox
                                        x:Name="GraphQlVariablesTextBox"
                                        AcceptsReturn="True"
                                        AcceptsTab="True"
                                        TextWrapping="NoWrap"
                                        VerticalScrollBarVisibility="Auto"
                                        HorizontalScrollBarVisibility="Auto"
                                        FontFamily="Cascadia Code, Consolas"
                                        FontSize="13"
                                        MinHeight="80"
                                        MaxHeight="150"/>
                                </StackPanel>

                            </StackPanel>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter
                Grid.Row="2"
                Height="6"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                ResizeBehavior="PreviousAndNext"
                ResizeDirection="Rows"/>

            <!-- Response -->
            <Border
                Grid.Row="3"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Background="{StaticResource SurfaceBrush}"
                Effect="{StaticResource CardShadowEffect}"
                Padding="12">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock
                            Text="Response"
                            FontWeight="Bold"
                            FontSize="13"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            VerticalAlignment="Center"/>

                        <Border
                            x:Name="StatusBadge"
                            Margin="10,0,0,0"
                            Padding="8,3"
                            CornerRadius="4"
                            Background="{StaticResource BorderBrush}"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                            <TextBlock
                                x:Name="StatusTextBlock"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Border>

                        <TextBlock
                            x:Name="TimingTextBlock"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{StaticResource TextSecondaryBrush}"/>

                        <ProgressBar
                            x:Name="SendProgressBar"
                            Width="140"
                            Margin="10,0,0,0"
                            IsIndeterminate="True"
                            Visibility="Collapsed"
                            VerticalAlignment="Center"/>
                    </StackPanel>

                    <Expander
                        Grid.Row="1"
                        Header="Response Headers"
                        IsExpanded="False"
                        Margin="0,0,0,10">
                        <TextBox
                            x:Name="ResponseHeadersTextBox"
                            Margin="0,10,0,0"
                            IsReadOnly="True"
                            TextWrapping="NoWrap"
                            MaxHeight="150"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Auto"
                            FontFamily="Cascadia Code, Consolas"
                            FontSize="12"/>
                    </Expander>

                    <avalonedit:TextEditor
                        x:Name="ResponseBodyEditor"
                        Grid.Row="2"
                        FontFamily="Cascadia Code, Consolas"
                        FontSize="13"
                        ShowLineNumbers="True"
                        IsReadOnly="True"
                        WordWrap="False"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto"
                        Padding="8"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

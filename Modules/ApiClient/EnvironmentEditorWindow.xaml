<Window
    x:Class="KubaToolKit.Modules.ApiClient.EnvironmentEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Edit Environment"
    Width="600"
    Height="520"
    MinWidth="420"
    MinHeight="320"
    WindowStartupLocation="CenterOwner"
    Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="Environment"
            FontWeight="Bold"
            FontSize="15"
            Foreground="{StaticResource TextPrimaryBrush}"
            Margin="0,0,0,10"/>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Text="Name"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextSecondaryBrush}"
                VerticalAlignment="Center"
                Margin="0,0,8,0"/>

            <TextBox
                x:Name="NameTextBox"
                Grid.Column="1"
                VerticalContentAlignment="Center"/>
        </Grid>

        <Border
            Grid.Row="2"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{StaticResource SurfaceBrush}"
            Effect="{StaticResource CardShadowEffect}"
            Padding="10">

            <DataGrid
                x:Name="VariablesGrid"
                AutoGenerateColumns="False"
                CanUserAddRows="True"
                CanUserDeleteRows="True"
                HeadersVisibility="Column"
                HorizontalScrollBarVisibility="Auto"
                RowHeight="32">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn
                        Header="On"
                        Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                        Width="Auto"/>

                    <DataGridTextColumn
                        Header="Key"
                        Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                        CellStyle="{StaticResource EditableDataGridCellStyle}"
                        Width="220"/>

                    <DataGridTextColumn
                        Header="Value"
                        Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                        CellStyle="{StaticResource EditableDataGridCellStyle}"
                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel
            Grid.Row="3"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Margin="0,12,0,0">

            <Button
                Width="100"
                Margin="0,0,8,0"
                Content="Cancel"
                Click="CancelButton_Click"/>

            <Button
                Width="100"
                Style="{StaticResource AccentButtonStyle}"
                Content="Save"
                Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>

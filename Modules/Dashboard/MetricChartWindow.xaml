<Window
    x:Class="KubaToolKit.Modules.Dashboard.MetricChartWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:KubaToolKit.Shared.Behaviors"
    Title="Metric"
    Width="760"
    Height="520"
    MinWidth="520"
    MinHeight="400"
    WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,4">
            <TextBlock
                x:Name="TitleTextBlock"
                FontWeight="Bold"
                FontSize="16"
                Foreground="{StaticResource TextPrimaryBrush}"/>

            <TextBlock
                x:Name="SubtitleTextBlock"
                FontSize="12"
                Foreground="{StaticResource TextSecondaryBrush}"
                Margin="0,2,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,14" VerticalAlignment="Center">
            <TextBlock
                Text="Start"
                VerticalAlignment="Center"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextSecondaryBrush}"
                Margin="0,0,8,0"/>

            <DatePicker x:Name="StartDatePicker" Width="110" VerticalContentAlignment="Center"/>

            <TextBox
                x:Name="StartTimeTextBox"
                Width="80"
                Margin="6,0,0,0"
                VerticalContentAlignment="Center"
                HorizontalContentAlignment="Center"
                behaviors:TimeEntryBehavior.Enabled="True"/>

            <TextBlock
                Text="End"
                VerticalAlignment="Center"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextSecondaryBrush}"
                Margin="20,0,8,0"/>

            <DatePicker x:Name="EndDatePicker" Width="110" VerticalContentAlignment="Center"/>

            <TextBox
                x:Name="EndTimeTextBox"
                Width="80"
                Margin="6,0,0,0"
                VerticalContentAlignment="Center"
                HorizontalContentAlignment="Center"
                behaviors:TimeEntryBehavior.Enabled="True"/>

            <Button
                Content="Apply"
                Margin="16,0,0,0"
                Padding="14,0"
                Height="26"
                Style="{StaticResource AccentButtonStyle}"
                Click="ApplyRangeButton_Click"/>
        </StackPanel>

        <StackPanel
            x:Name="LegendPanel"
            Grid.Row="2"
            Orientation="Horizontal"
            Margin="0,6,0,0"
            Visibility="Collapsed"/>

        <ProgressBar
            x:Name="LoadingProgressBar"
            Grid.Row="3"
            Margin="0,10,0,10"
            IsIndeterminate="True"
            Visibility="Collapsed"/>

        <Border
            Grid.Row="4"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource RadiusMedium}"
            Background="{StaticResource SurfaceBrush}"
            Effect="{StaticResource CardShadowEffect}"
            Padding="{StaticResource SpaceLg}">

            <Grid x:Name="ChartHost" SizeChanged="ChartHost_SizeChanged">
                <TextBlock
                    x:Name="EmptyStateText"
                    Text="No data for this period."
                    Foreground="{StaticResource TextMutedBrush}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed"/>

                <Canvas x:Name="ChartCanvas" ClipToBounds="True"/>

                <Canvas
                    x:Name="OverlayCanvas"
                    Background="Transparent"
                    MouseMove="OverlayCanvas_MouseMove"
                    MouseLeave="OverlayCanvas_MouseLeave"
                    MouseLeftButtonDown="OverlayCanvas_MouseLeftButtonDown"
                    MouseLeftButtonUp="OverlayCanvas_MouseLeftButtonUp">

                    <Rectangle
                        x:Name="SelectionRectangle"
                        Fill="{StaticResource AccentBrush}"
                        Opacity="0.15"
                        IsHitTestVisible="False"
                        Visibility="Collapsed"/>

                    <Line
                        x:Name="CrosshairLine"
                        Stroke="{StaticResource BorderBrush}"
                        StrokeThickness="1"
                        StrokeDashArray="2,2"
                        IsHitTestVisible="False"
                        Visibility="Collapsed"/>

                    <Border
                        x:Name="TooltipBorder"
                        Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSmall}"
                        Padding="8,6"
                        IsHitTestVisible="False"
                        Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock
                                x:Name="TooltipTimeText"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"/>
                            <StackPanel x:Name="TooltipValuesPanel" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </Canvas>
            </Grid>
        </Border>
    </Grid>
</Window>

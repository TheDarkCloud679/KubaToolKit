<Window
    x:Class="KubaToolKit.Modules.Dashboard.Ec2DiskReportWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="EC2 disk report"
    Width="640"
    Height="600"
    MinWidth="480"
    MinHeight="360"
    WindowStartupLocation="CenterScreen"
    Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock
                FontWeight="Bold"
                FontSize="15"
                Text="Disk usage across all EC2 instances"
                Foreground="{StaticResource TextPrimaryBrush}"/>

            <TextBlock
                x:Name="SummaryTextBlock"
                FontSize="12"
                Margin="0,4,0,0"
                Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <DataGrid
            x:Name="ReportGrid"
            Grid.Row="1"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            CanUserSortColumns="False"
            HeadersVisibility="Column"
            HorizontalScrollBarVisibility="Auto"
            VirtualizingPanel.ScrollUnit="Pixel"
            RowHeight="36"
            MouseDoubleClick="ReportGrid_MouseDoubleClick">

            <DataGrid.Columns>
                <DataGridTextColumn
                    Header="Instance"
                    Binding="{Binding InstanceName}"
                    SortMemberPath="InstanceName"
                    Width="*"/>

                <DataGridTextColumn
                    Header="Mount"
                    Binding="{Binding MountPath}"
                    SortMemberPath="MountPath"
                    Width="140"/>

                <DataGridTemplateColumn
                    Header="Used"
                    SortMemberPath="UsedPercent"
                    Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border
                                Padding="10,4"
                                CornerRadius="4"
                                HorizontalAlignment="Left"
                                Background="{Binding UsedPercentBackground}">
                                <TextBlock
                                    Text="{Binding UsedPercentDisplay}"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>

<UserControl
    x:Class="KubaToolKit.Modules.Dashboard.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Text="Dashboard"
                FontWeight="Bold"
                FontSize="14"
                Foreground="{StaticResource TextPrimaryBrush}"
                VerticalAlignment="Center"/>

            <ProgressBar
                x:Name="LoadingProgressBar"
                Grid.Column="1"
                Margin="16,0"
                Visibility="Collapsed"
                IsIndeterminate="True"
                VerticalAlignment="Center"/>

            <Button
                x:Name="RefreshButton"
                Grid.Column="2"
                Width="100"
                Content="Refresh"
                Click="RefreshButton_Click"/>
        </Grid>

        <!-- Metric sections -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock
                    Text="RDS Instances"
                    FontWeight="SemiBold"
                    FontSize="13"
                    Foreground="{StaticResource TextSecondaryBrush}"/>

                <TextBlock
                    Text="(double-click a metric for its 1h chart)"
                    FontSize="11"
                    FontStyle="Italic"
                    Foreground="{StaticResource TextMutedBrush}"
                    Margin="8,0,0,0"
                    VerticalAlignment="Bottom"/>
            </StackPanel>

            <Border
                Grid.Row="1"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Background="{StaticResource SurfaceBrush}"
                Effect="{StaticResource CardShadowEffect}"
                Padding="8">

                <DataGrid
                    x:Name="RdsGrid"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    HeadersVisibility="Column"
                    RowHeight="40">

                    <DataGrid.Resources>
                        <!--
                            Le fond (dégradé bleu -> rouge selon la charge) est
                            posé en local via Binding sur chaque cellule, donc
                            le survol se signale via la bordure plutôt que le
                            fond pour ne pas l'écraser.
                        -->
                        <Style x:Key="MetricCellStyle" TargetType="Border">
                            <Setter Property="Padding" Value="10,4"/>
                            <Setter Property="Margin" Value="0,0,4,0"/>
                            <Setter Property="CornerRadius" Value="4"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalAlignment" Value="Left"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Header="DB Instance"
                            Binding="{Binding Identifier}"
                            Width="*"/>

                        <DataGridTextColumn
                            Header="Engine"
                            Binding="{Binding Engine}"
                            Width="140"/>

                        <DataGridTemplateColumn
                            Header="Status"
                            Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border
                                        Padding="10,4"
                                        CornerRadius="4"
                                        HorizontalAlignment="Left"
                                        Background="{Binding StatusBackground}">
                                        <TextBlock
                                            Text="{Binding Status}"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn
                            Header="CPU"
                            Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border
                                        Style="{StaticResource MetricCellStyle}"
                                        Background="{Binding CpuBackground}"
                                        MouseLeftButtonDown="CpuMetric_MouseLeftButtonDown">
                                        <TextBlock
                                            Text="{Binding CpuDisplay}"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn
                            Header="Activity"
                            Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border
                                        Style="{StaticResource MetricCellStyle}"
                                        Background="{Binding ActivityBackground}"
                                        MouseLeftButtonDown="ActivityMetric_MouseLeftButtonDown">
                                        <TextBlock
                                            Text="{Binding ActivityDisplay}"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

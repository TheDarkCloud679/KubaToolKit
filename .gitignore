/.vs
/bin
/obj

# Personal AWS SSO reference files (see Config/README.md)
Config/config
Config/credentials

# Project Info glossary (contacts, network/VPN details...) -- contains PII,
# not committed by default. Share the file directly with your team, or
# remove this line if you'd rather version it in git instead.
Config/project-info.json

# Files dropped in a project's "Dossier de fichiers" shortcut (Project
# Info window) -- arbitrary documents, same reasoning as project-info.json
# above: shared directly between colleagues, not meant for git.
Config/ProjectFiles/

# Wiki notes, same reasoning as project-info.json above.
Config/wiki.json

# Per-user Visual Studio project settings (machine-specific paths)
*.csproj.user

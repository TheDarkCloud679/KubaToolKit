<Window x:Class="KubaToolKit.Shared.Windows.JsonViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Log Viewer"
        Height="800"
        Width="1300"
        MinHeight="500"
        MinWidth="800"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="14" Background="{StaticResource WindowBackgroundBrush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <DockPanel Grid.Row="0"
                   Margin="0,0,0,10">

            <TextBlock
                Text="Formatted Log Message"
                FontSize="16"
                FontWeight="Bold"
                Foreground="{StaticResource TextPrimaryBrush}"
                VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right">

                <Button x:Name="CopyButton"
                        Width="120"
                        Style="{StaticResource AccentButtonStyle}"
                        Margin="8,0,0,0"
                        Content="📋 Copy"
                        Click="CopyButton_Click"/>
            </StackPanel>

        </DockPanel>

        <!-- JSON -->
        <Border Grid.Row="1"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Background="{StaticResource SurfaceBrush}"
                Effect="{StaticResource CardShadowEffect}">

            <avalonedit:TextEditor
                x:Name="JsonTextBox"
                FontFamily="Cascadia Code, Consolas"
                FontSize="14"
                ShowLineNumbers="True"
                IsReadOnly="True"
                WordWrap="False"
                Background="Transparent"
                BorderThickness="0"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto"
                Padding="12"/>
        </Border>

        <!-- Footer -->
        <StatusBar Grid.Row="2"
                   Margin="0,10,0,0">

            <StatusBarItem>
                <TextBlock x:Name="JsonInfoText"/>
            </StatusBarItem>

        </StatusBar>

    </Grid>
</Window>